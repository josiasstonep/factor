# Factor — Chaves de API para melhoria de laudos com IA
# Copie este arquivo para .env e preencha as chaves que você usar.
# O .env NÃO é versionado no git (já está no .gitignore).

# Groq — gratuito, recomendado para começar
# Crie em: https://console.groq.com
GROQ_API_KEY=

# Google Gemini — gratuito (1M tokens/dia)
# Crie em: https://aistudio.google.com
GEMINI_API_KEY=

# Anthropic (Claude Haiku) — ~R$0,01 por laudo, melhor qualidade
# Crie em: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o mini) — opcional
# Crie em: https://platform.openai.com
OPENAI_API_KEY=
